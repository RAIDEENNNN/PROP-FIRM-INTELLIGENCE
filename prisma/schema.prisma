generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TRADER
  PRO
  ADMIN
  SUPER_ADMIN
}

enum SubscriptionStatus {
  FREE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  EXTREME
}

enum ImpactLevel {
  LOW
  MEDIUM
  HIGH
}

enum AlertType {
  RULE_CHANGE
  SPREAD_SPIKE
  NEWS_EVENT
  PAYOUT_UPDATE
  PRICE_CHANGE
  CUSTOM
}

enum ReviewStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ChallengeType {
  ONE_STEP
  TWO_STEP
  THREE_STEP
  INSTANT_FUNDING
}

enum InstrumentCategory {
  FOREX
  CRYPTO
  INDICES
  COMMODITIES
  STOCKS
}

enum TradingSession {
  ASIA
  LONDON
  NEW_YORK
  OVERLAP
}

model User {
  id                    String               @id @default(cuid())
  email                 String               @unique
  passwordHash          String
  name                  String?
  avatarUrl             String?
  role                  Role                 @default(TRADER)
  subscriptionStatus    SubscriptionStatus   @default(FREE)
  emailVerifiedAt       DateTime?
  lastLoginAt           DateTime?
  refreshTokenHash      String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  traderProfile         TraderProfile?
  watchlists            Watchlist[]
  alerts                Alert[]
  reviews               Review[]
  subscriptions         Subscription[]
  kycVerifications      KycVerification[]
  auditLogs             AuditLog[]
  journalEntries        JournalEntry[]
  notifications         Notification[]
  savedToolResults      SavedToolResult[]
}

model TraderProfile {
  id                    String       @id @default(cuid())
  userId                String       @unique
  experienceLevel       String?
  strategy              String?
  preferredMarkets      String[]
  maxDailyDrawdown      Decimal?
  maxTotalDrawdown      Decimal?
  preferredAccountSize  Int?
  riskTolerance         RiskLevel    @default(MEDIUM)
  payoutPriority        Boolean      @default(false)
  swingTrading          Boolean      @default(false)
  newsTrading           Boolean      @default(false)
  eaTrading             Boolean      @default(false)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PropFirm {
  id                    String              @id @default(cuid())
  name                  String
  slug                  String              @unique
  logoUrl               String?
  websiteUrl            String?
  affiliateUrl          String?
  country               String?
  trustScore            Decimal             @default(0)
  rating                Decimal             @default(0)
  reviewCount           Int                 @default(0)
  foundedYear           Int?
  payoutFrequency       String?
  status                String              @default("active")
  editorSummary         String?
  seoTitle              String?
  seoDescription        String?
  featured              Boolean             @default(false)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  accounts              PropFirmAccount[]
  rules                 PropFirmRule[]
  reviews               Review[]
  watchlists            Watchlist[]
  alerts                Alert[]
  auditLogs             AuditLog[]
}

model PropFirmAccount {
  id                    String          @id @default(cuid())
  firmId                String
  name                  String
  challengeType         ChallengeType
  accountSize           Int
  challengeFee          Decimal
  profitTargetPhaseOne  Decimal?
  profitTargetPhaseTwo  Decimal?
  dailyDrawdown         Decimal?
  maxDrawdown           Decimal?
  profitSplit           Decimal?
  minimumTradingDays    Int?
  maxTradingDays        Int?
  refundableFee         Boolean         @default(false)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  firm                  PropFirm        @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([accountSize])
}

model PropFirmRule {
  id                    String          @id @default(cuid())
  firmId                String
  category              String
  title                 String
  currentValue          String
  previousValue         String?
  impactLevel           ImpactLevel     @default(MEDIUM)
  effectiveAt           DateTime?
  sourceUrl             String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  firm                  PropFirm        @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId, category])
}

model Instrument {
  id                    String              @id @default(cuid())
  symbol                String              @unique
  name                  String
  category              InstrumentCategory
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  spreadRecords         SpreadRecord[]
}

model SpreadRecord {
  id                    String          @id @default(cuid())
  instrumentId          String
  brokerOrFirm          String
  bid                   Decimal?
  ask                   Decimal?
  spreadPips            Decimal
  session               TradingSession?
  recordedAt            DateTime        @default(now())

  instrument            Instrument      @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@index([instrumentId, recordedAt])
  @@index([brokerOrFirm])
}

model NewsEvent {
  id                    String          @id @default(cuid())
  title                 String
  summary               String?
  sourceName            String?
  sourceUrl             String?
  affectedFirms         String[]
  affectedSymbols       String[]
  impactLevel           ImpactLevel     @default(MEDIUM)
  publishedAt           DateTime
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model Watchlist {
  id                    String          @id @default(cuid())
  userId                String
  firmId                String
  notes                 String?
  createdAt             DateTime        @default(now())

  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  firm                  PropFirm        @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@unique([userId, firmId])
}

model Alert {
  id                    String          @id @default(cuid())
  userId                String
  firmId                String?
  type                  AlertType
  title                 String
  message               String
  triggerConfig         Json?
  enabled               Boolean         @default(true)
  lastTriggeredAt       DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  firm                  PropFirm?       @relation(fields: [firmId], references: [id], onDelete: SetNull)

  @@index([userId, enabled])
}

model Review {
  id                    String          @id @default(cuid())
  userId                String
  firmId                String
  rating                Int
  title                 String
  body                  String
  payoutProofUrl        String?
  status                ReviewStatus    @default(PENDING)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  firm                  PropFirm        @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId, status])
}

model Subscription {
  id                    String              @id @default(cuid())
  userId                String
  stripeCustomerId      String?
  stripeSubscriptionId  String?             @unique
  plan                  String
  status                SubscriptionStatus
  currentPeriodEnd      DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model KycVerification {
  id                    String          @id @default(cuid())
  userId                String
  provider              String?
  providerReference     String?
  status                KycStatus       @default(NOT_STARTED)
  reviewedAt            DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id                    String          @id @default(cuid())
  actorUserId           String?
  firmId                String?
  action                String
  entityType            String
  entityId              String?
  metadata              Json?
  createdAt             DateTime        @default(now())

  actor                User?            @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  firm                 PropFirm?        @relation(fields: [firmId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
}

model JournalEntry {
  id                    String          @id @default(cuid())
  userId                String
  title                 String
  firmName              String?
  accountSize           Int?
  startingBalance       Decimal?
  currentBalance        Decimal?
  dailyDrawdownLimit    Decimal?
  maxDrawdownLimit      Decimal?
  notes                 String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id                    String          @id @default(cuid())
  userId                String
  title                 String
  message               String
  readAt                DateTime?
  createdAt             DateTime        @default(now())

  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedToolResult {
  id                    String          @id @default(cuid())
  userId                String
  toolName              String
  input                 Json
  result                Json
  createdAt             DateTime        @default(now())

  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, toolName])
}
