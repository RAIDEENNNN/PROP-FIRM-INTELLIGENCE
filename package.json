{
  "name": "fundedscope-platform",
  "version": "0.1.0",
  "private": true,
  "description": "FundedScope premium trader intelligence platform.",
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @fundedscope/web",
    "dev:web": "npm run dev --workspace @fundedscope/web",
    "dev:api": "npm run dev --workspace @fundedscope/api",
    "build:web": "npm run build --workspace @fundedscope/web",
    "build:api": "npm run build --workspace @fundedscope/api",
    "start:api": "npm run start --workspace @fundedscope/api",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "lint": "npm run lint --workspaces",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "prisma": "^5.20.0"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.8.1",
    "typescript": "^5.6.3"
  }
}
